# Desarrollo local
VITE_APP_ENV=development
VITE_APP_VERSION=6.0.0
VITE_APP_BRAND_NAME=Sistema Veterinaria
VITE_SUPPORT_EMAIL=

# Firebase web app config
# Usar valores del proyecto Firebase de desarrollo o dejar vacio para demo local.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_TENANT_ID=defaultVet

# Runtime
VITE_USE_FIREBASE=false
VITE_REQUIRE_FIREBASE=false
VITE_USE_FIREBASE_EMULATORS=false
VITE_ALLOW_LOCAL_DEMO=true
VITE_ALLOW_DEMO_SEED=true

# App Check
VITE_REQUIRE_APPCHECK=false
VITE_FIREBASE_APPCHECK_SITE_KEY=
VITE_APPCHECK_DEBUG_TOKEN=
